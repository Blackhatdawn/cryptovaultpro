# ==========================================
# CRYPTOVAULT PRODUCTION - ENVIRONMENT CONFIG
# ==========================================
# 
# DEPLOYMENT: Render (Backend) | Vercel (Frontend)
# Created: April 3, 2026
#
# INSTRUCTIONS:
# 1. Copy: cp .env.example .env
# 2. Update: Replace placeholder values
# 3. NEVER: Commit .env to version control
# 4. Store: Use Render Secrets Manager for sensitive values
#
# ==========================================
# CORE APPLICATION
# ==========================================

# Application metadata
APP_NAME=CryptoVault Pro
APP_VERSION=2.0.0

# Environment: development, staging, production
# Each has different security requirements
ENVIRONMENT=production

# Debug mode: NEVER true in production
DEBUG=false

# Production mode: Enforces all security requirements
FULL_PRODUCTION_CONFIGURATION=true

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server host and port
# HOST must be 0.0.0.0 for containerized/cloud deployments
HOST=0.0.0.0

# Port number
# On Render/Railway, the platform assigns PORT automatically
# Set here for local development
PORT=8000

# Number of Gunicorn workers (1-8 recommended)
# Higher for production, lower for development
WORKERS=1

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MongoDB connection string
# Format: mongodb+srv://user:password@cluster.mongodb.net/?appName=AppName
# Get from MongoDB Atlas: https://cloud.mongodb.com
MONGO_URL=mongodb://localhost:27017

# Database name
DB_NAME=cryptovault

# Connection pool settings
MONGO_MAX_POOL_SIZE=10          # Max concurrent connections
MONGO_TIMEOUT_MS=5000           # Server selection timeout

# ============================================
# REDIS / CACHING
# ============================================

# Enable/disable Redis caching
USE_REDIS=false

# Standard Redis connection (if not using Upstash)
# Format: redis://[:password]@host:port
# Leave empty if using Upstash REST API
REDIS_URL=

# Upstash REST API (serverless alternative)
# https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Redis key prefix
REDIS_PREFIX=cryptovault:

# ============================================
# SECURITY & AUTHENTICATION
# ============================================

# JWT secret key (MUST be 32+ characters in production!)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production

# JWT algorithm (HS256, RS256, etc.)
JWT_ALGORITHM=HS256

# Admin JWT secret (optional, independent from user JWT)
# If not set, derived from JWT_SECRET (not recommended for production)
ADMIN_JWT_SECRET=

# CSRF protection secret
CSRF_SECRET=change-me-in-production

# Token expiration times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cross-site cookie settings (for SPA development)
USE_CROSS_SITE_COOKIES=false

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Frontend application URL
# Must match browser origin for CORS
APP_URL=http://localhost:3000

# Public API URL (for frontend config)
# Frontend will make requests to this URL
PUBLIC_API_URL=http://localhost:8000

# Public WebSocket URL (for real-time updates)
PUBLIC_WS_URL=ws://localhost:8000

# Socket.IO path
PUBLIC_SOCKET_IO_PATH=/socket.io/

# CORS origins (comma-separated or JSON array)
# Must include frontend domain(s)
CORS_ORIGINS='["http://localhost:3000"]'

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Email service: smtp, sendgrid, resend, mock
EMAIL_SERVICE=mock

# Email service API keys
SENDGRID_API_KEY=
RESEND_API_KEY=

# Default sender
EMAIL_FROM=support@cryptovaultpro.finance
EMAIL_FROM_NAME=CryptoVault Pro

# Email verification URL (for email verification links)
EMAIL_VERIFICATION_URL=http://localhost:3000/verify

# SMTP Configuration (if using SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ============================================
# EXTERNAL CRYPTO SERVICES
# ============================================

# CoinCap market data service
COINCAP_API_KEY=
COINCAP_API_URL=https://api.coincap.io/v2
COINCAP_WS_URL=wss://ws.coincap.io/prices
COINCAP_RATE_LIMIT=200

# CoinMarketCap (fallback, optional)
# Free tier: 30 requests/min
COINMARKETCAP_API_KEY=

# Use mock price data (development)
USE_MOCK_PRICES=true

# ============================================
# PAYMENT PROCESSING
# ============================================

# NOWPayments integration for crypto payments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=true
ALLOW_MOCK_PAYMENT_FALLBACK=true

# ============================================
# S3 STORAGE (KYC Documents, Audit Logs)
# ============================================

# S3-compatible storage
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1

# S3 bucket names
S3_BUCKET_KYC=cryptovault-kyc-documents
S3_BUCKET_AUDIT=cryptovault-audit-logs

# ============================================
# RATE LIMITING
# ============================================

# Requests allowed per minute
RATE_LIMIT_PER_MINUTE=60

# Enable/disable rate limiting
RATE_LIMIT_ENABLED=true

# Rate limit default message
RATE_LIMIT_DEFAULT=100 per minute

# ============================================
# FEATURE FLAGS
# ============================================

# Enable/disable specific features
FEATURE_KYC_ENABLED=true
FEATURE_2FA_ENABLED=true
FEATURE_DEPOSITS_ENABLED=true
FEATURE_WITHDRAWALS_ENABLED=true
FEATURE_TRANSFERS_ENABLED=true
FEATURE_TRADING_ENABLED=true
FEATURE_STAKING_ENABLED=false

# ============================================
# GEO-BLOCKING (Optional)
# ============================================

# Comma-separated ISO country codes to block
# Example: KP,IR,CU,SY (OFAC countries)
BLOCKED_COUNTRIES=

# GeoIP database configuration
GEOIP_DB_PATH=
MAXMIND_LICENSE_KEY=

# ============================================
# FIREBASE (Optional)
# ============================================

# Path to Firebase credentials JSON file
FIREBASE_CREDENTIALS_PATH=

# Or Firebase credentials as JSON string
FIREBASE_CREDENTIAL=

# ============================================
# TELEGRAM NOTIFICATIONS (Optional)
# ============================================

# Enable Telegram bot for admin notifications
TELEGRAM_ENABLED=false

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Admin chat ID(s) for notifications (comma-separated)
ADMIN_TELEGRAM_CHAT_ID=

# ============================================
# ERROR TRACKING & MONITORING
# ============================================

# Sentry (error tracking & performance monitoring)
SENTRY_DSN=

# Sentry sampling rates (0.0 to 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Frontend Sentry DSN (sent to client)
PUBLIC_SENTRY_DSN=

# ============================================
# LOGGING
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (production) or text
LOG_FORMAT=text

# ============================================
# BRANDING (Frontend Configuration)
# ============================================

# Public site name (shown to users)
PUBLIC_SITE_NAME=CryptoVault Pro

# Public logo URL
PUBLIC_LOGO_URL=

# Public support email
PUBLIC_SUPPORT_EMAIL=support@cryptovaultpro.finance

# ============================================
# WEBHOOK TESTING (Development Only)
# ============================================

# Enable /api/wallet/webhook/test endpoint
# Should be false in production
ENABLE_WEBHOOK_TEST_ENDPOINT=false
#   IMAP: mail.spacemail.com port 993 SSL
#   POP3: mail.spacemail.com port 995 SSL
# ============================================
EMAIL_SERVICE=smtp
SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_USERNAME=support@cryptovaultpro.finance
SMTP_PASSWORD=Kelechi52@
SMTP_USE_TLS=false
SMTP_USE_SSL=true

# Email sender configuration:
EMAIL_FROM=securedvault@cryptovaultpro.finance
EMAIL_FROM_NAME=CryptoVault Pro
EMAIL_VERIFICATION_URL=https://cryptovaultpro.finance/verify

# Alternative email providers:
# SENDGRID_API_KEY=
# RESEND_API_KEY=

# External Crypto Services
COINCAP_API_KEY=
COINCAP_RATE_LIMIT=50
USE_MOCK_PRICES=false

# CoinMarketCap (fallback provider - free tier 30 req/min)
# Get your free API key at: https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=97e89f741da04e7e99ddfa0b6d1afac2

# Payments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false
ALLOW_MOCK_PAYMENT_FALLBACK=false

# Redis / Cache
USE_REDIS=true
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=
REDIS_PREFIX=cryptovault:

# S3 Storage (KYC Documents, Audit Logs)
# Supports S3-compatible providers (AWS, MinIO, Hostkey, etc.)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
S3_BUCKET_KYC=cryptovault-kyc-documents
S3_BUCKET_AUDIT=cryptovault-audit-logs

# GeoIP / Country Blocking
# Download free GeoLite2-Country.mmdb from: https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
GEOIP_DB_PATH=
MAXMIND_LICENSE_KEY=
BLOCKED_COUNTRIES=

# Telegram
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_CHAT_ID=

# Feature flags
FEATURE_2FA_ENABLED=true
FEATURE_DEPOSITS_ENABLED=true
FEATURE_WITHDRAWALS_ENABLED=true
FEATURE_TRANSFERS_ENABLED=true
FEATURE_TRADING_ENABLED=true
FEATURE_STAKING_ENABLED=false

# Monitoring
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1